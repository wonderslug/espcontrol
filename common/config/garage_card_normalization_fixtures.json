      "entity": "cover.garage",
      "label": "Garage Door",
      "icon": "Garage",
      "icon_on": "Garage Open",
      "sensor": "",
      "unit": "",
      "type": "garage",
      "precision": "",
      "options": "label_display=status"
    }
  },
  {
